@using Core.ViewModels.Subscription
@model CreateSubscriptionModel

@{
    ViewData["Title"] = "Subscribe";
}

<h1>Subscribe</h1>

<h4>Subscription</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Subscribe">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <input hidden asp-for="Price" class="form-control" value="5.3" />
            </div>
            <div class="form-group">
                <input hidden asp-for="Days" class="form-control" value="5" />
            </div>
            <div hidden class="form-group">
                <input name="UserId" class="form-control" value=@ViewBag.UserId />
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}
