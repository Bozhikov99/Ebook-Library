            *@
            <div class="col" style="background-color: #212529; margin-top: 4rem">
                <div class="row align-middle">
                    <div class="col">
                        <h2 style="padding: 1rem; color: white">Review:</h2>
                    </div>
                    <input hidden name="UserId" value=@ViewBag.UserId />
                    <input hidden name="BookId" value=@Model.Id />
                    <input hidden name="Comment" />
                    <div class="col ">
                        @for (int i = 0; i < 5; i++)
                        {
                            <i class="bi bi-star-fill" style="font-size: 2rem; color:white;"></i>
                        }
                    </div>
                </div>
            </div>
            <div>
                <textarea class="form-control"
                  rows="6"
                  style="border-color: #f15a24"></textarea>
            </div>
            <div class="row">
                <div class="col d-flex justify-content-end">
                    <button id="submit-review" class="btn navbutton"
