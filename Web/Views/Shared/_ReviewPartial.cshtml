@using Core.ViewModels.Review

@if (ViewBag.UserId != null)
{
    <div id="partial">
        @if (ViewBag.UserReview != null)
        {
            <div id="commentDiv">
                <p id="comment">@ViewBag.UserReview.Comment</p>
                <p>@ViewBag.UserReview.Value</p>
                <button id="edit">Edit</button>
                <button id="delete">Delete</button>
                <p id="review-id" hidden>@ViewBag.UserReview.Id</p>
            </div>
        }
        else
        {
            @*<form asp-action="CreateReview">*@
