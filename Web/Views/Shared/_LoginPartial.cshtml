@using Infrastructure.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="" asp-controller="User" asp-action="Profile" title="Manage">Hello @User.Identity?.Name!</a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
        @await Component.InvokeAsync("AdminCheck")
    }
    else
    {
        <!-- Login/Register Buttons -->

        <div class="nav-item px-2 d-none d-lg-block">
            <a class="btn navbutton"
           asp-controller="User"
           asp-action="Login">Login</a>
        </div>
        <div class="nav-item px-2 d-none d-lg-block">
            <a class="btn navbutton" asp-controller="User"
           asp-action="Register">Register</a>
        </div>
    }
</ul>
